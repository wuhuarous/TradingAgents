# ===== LLM Providers (至少填一个) =====
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=sk-ant-your-key-here

# 默认使用的 LLM (deepseek / openai / anthropic)
LLM_PROVIDER=deepseek
DEEP_THINK_MODEL=deepseek-v4-pro
QUICK_THINK_MODEL=deepseek-v4-flash

# ===== 数据源（可选）=====
TUSHARE_TOKEN=your-token-here
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=
NEWSAPI_API_KEY=
TAVILY_API_KEY=

# ===== 数据库（Docker 部署无需修改）=====
POSTGRESQL_URL=postgresql+asyncpg://trading:trading123@postgres:5432/tradingagents
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=tradingagents
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
# ===== 服务端 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ===== 风控参数 =====
INITIAL_CAPITAL=1000000
SINGLE_POSITION_MAX_RATIO=0.2
TOTAL_POSITION_MAX_RATIO=0.8
DAILY_STOP_LOSS_RATIO=0.03
